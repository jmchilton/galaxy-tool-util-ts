{
  "name": "@galaxy-tool-util/gxwf-web",
  "version": "1.3.0",
  "description": "Galaxy workflow development HTTP server — validate, lint, clean, convert workflows",
  "type": "module",
  "bin": {
    "gxwf-web": "dist/bin/gxwf-web.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "public",
    "openapi.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jmchilton/galaxy-tool-util-ts",
    "directory": "packages/gxwf-web"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "copy-ui": "node scripts/copy-ui.mjs",
    "codegen": "openapi-typescript openapi.json -o src/generated/api-types.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "format-fix": "prettier --write 'src/**/*.ts' 'test/**/*.ts'"
  },
  "license": "MIT",
  "dependencies": {
    "@galaxy-tool-util/cli": "workspace:*",
    "@galaxy-tool-util/connection-validation": "workspace:*",
    "@galaxy-tool-util/core": "workspace:*",
    "@galaxy-tool-util/schema": "workspace:*",
    "effect": "^3.21.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "openapi-typescript": "^7.13.0"
  }
}
