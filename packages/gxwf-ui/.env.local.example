# Copy to .env.local (gitignored by Vite) to opt into the Monaco editor in
# FileView. Default builds use the basic textarea EditorShell and ship none
# of the @codingame/monaco-vscode-* runtime.
#
# Activation recipe (one-time per dev box):
#   1. Clone galaxy-workflows-vscode at the sha pinned in EXT_COMMIT.md.
#   2. `pnpm build && npx @vscode/vsce package --no-dependencies` in that repo.
#   3. Drop the resulting .vsix at packages/gxwf-ui/fixtures/galaxy-workflows.vsix.
#   4. Copy this file to .env.local.
#   5. `pnpm --filter @galaxy-tool-util/gxwf-ui build` (or `pnpm dev`).
#
# scripts/stage-extension.mjs unpacks the fixture into public/ext/galaxy-workflows/
# at prebuild/predev time; gxwf-web (and Vite in dev) serves it as static files.

# Render <MonacoEditor> instead of <EditorShell> in FileView.
VITE_GXWF_MONACO=1

# Where the extension comes from. `vsix:<url-prefix>` points at the unpacked
# directory staged from the fixture above. `folder:/abs/path` is the other
# supported form (live extension checkout via Vite /@fs; used by dev:with-ext).
VITE_GXWF_EXT_SOURCE=vsix:/ext/galaxy-workflows

# Exposes window.__gxwfMonaco + data-monaco-ready attribute for E2E hooks.
# Safe to leave on in dev; off by default in prod builds.
VITE_GXWF_EXPOSE_MONACO=1
