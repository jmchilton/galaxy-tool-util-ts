{
  "name": "@galaxy-tool-util/gxwf-ui",
  "version": "0.2.0",
  "description": "Vue 3 + PrimeVue frontend for the gxwf-web Galaxy workflow development server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --check 'src/**/*.{ts,vue}'",
    "format-fix": "prettier --write 'src/**/*.{ts,vue}'"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@galaxy-tool-util/gxwf-client": "workspace:*",
    "@galaxy-tool-util/gxwf-report-shell": "workspace:*",
    "@galaxy-tool-util/schema": "workspace:*",
    "@primevue/themes": "^4.3.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "vite": "^8.0.0",
    "vue-tsc": "^2.2.0"
  }
}
