{
  "$schema": "vscode://schemas/color-theme",
  "name": "Galaxy Workflows Light",
  "type": "light",
  "colors": {
    "editor.background": "#f5f5f6",
    "editor.foreground": "#2c3143",
    "editor.lineHighlightBackground": "#e6e6e7",
    "editor.lineHighlightBorder": "#e6e6e700",
    "editor.selectionBackground": "#d0bd2a55",
    "editor.inactiveSelectionBackground": "#d0bd2a33",
    "editor.selectionHighlightBackground": "#d0bd2a33",
    "editor.findMatchBackground": "#d0bd2a88",
    "editor.findMatchHighlightBackground": "#d0bd2a55",
    "editorWhitespace.foreground": "#d0d0d1",
    "editorIndentGuide.background1": "#d0d0d1",
    "editorIndentGuide.activeBackground1": "#a19321",
    "editorRuler.foreground": "#d0d0d1",
    "editorCursor.foreground": "#736817",
    "editorLineNumber.foreground": "#878789",
    "editorLineNumber.activeForeground": "#736817",
    "editorBracketMatch.background": "#d0bd2a44",
    "editorBracketMatch.border": "#a19321",
    "editorBracketHighlight.foreground1": "#736817",
    "editorBracketHighlight.foreground2": "#a19321",
    "editorBracketHighlight.foreground3": "#2e689a",
    "editorBracketHighlight.foreground4": "#4f4e50",
    "editorBracketHighlight.foreground5": "#6c6c6e",
    "editorBracketHighlight.foreground6": "#afafb1",
    "editorError.foreground": "#cd3131",
    "editorError.background": "#cd313100",
    "editorError.border": "#cd313100",
    "editorWarning.foreground": "#a19321",
    "editorWarning.background": "#a1932100",
    "editorWarning.border": "#a1932100",
    "editorInfo.foreground": "#2e689a",
    "editorInfo.background": "#2e689a00",
    "editorInfo.border": "#2e689a00",
    "editorHint.foreground": "#878789",
    "editorWidget.background": "#ffffff",
    "editorWidget.foreground": "#2c3143",
    "editorWidget.border": "#d0d0d1",
    "editorHoverWidget.background": "#ffffff",
    "editorHoverWidget.foreground": "#2c3143",
    "editorHoverWidget.border": "#a19321",
    "editorSuggestWidget.background": "#ffffff",
    "editorSuggestWidget.foreground": "#2c3143",
    "editorSuggestWidget.border": "#d0d0d1",
    "editorSuggestWidget.selectedBackground": "#e6e6e7",
    "editorSuggestWidget.selectedForeground": "#2c3143",
    "editorSuggestWidget.highlightForeground": "#736817",
    "editorSuggestWidget.focusHighlightForeground": "#736817",
    "scrollbarSlider.background": "#d0d0d199",
    "scrollbarSlider.hoverBackground": "#afafb1cc",
    "scrollbarSlider.activeBackground": "#a19321",
    "focusBorder": "#a19321",
    "foreground": "#2c3143",
    "descriptionForeground": "#6c6c6e",
    "errorForeground": "#cd3131",
    "contrastBorder": "#d0d0d1"
  },
  "tokenColors": [
    {
      "name": "YAML key",
      "scope": ["entity.name.tag.yaml"],
      "settings": { "foreground": "#736817", "fontStyle": "bold" }
    },
    {
      "name": "JSON key",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#736817", "fontStyle": "bold" }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted.single.yaml",
        "string.quoted.double.yaml",
        "string.unquoted.plain.out.yaml",
        "string.quoted.double.json"
      ],
      "settings": { "foreground": "#a19321" }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric", "constant.numeric.yaml", "constant.numeric.json"],
      "settings": { "foreground": "#2e689a" }
    },
    {
      "name": "Constant language (true/false/null)",
      "scope": [
        "constant.language",
        "constant.language.boolean.yaml",
        "constant.language.null.yaml",
        "constant.language.json"
      ],
      "settings": { "foreground": "#2e689a" }
    },
    {
      "name": "Comment",
      "scope": ["comment", "comment.line.number-sign.yaml", "comment.block.json", "comment.line.json"],
      "settings": { "foreground": "#878789", "fontStyle": "italic" }
    },
    {
      "name": "YAML anchor",
      "scope": ["entity.other.attribute-name.alias.yaml"],
      "settings": { "foreground": "#a19321" }
    },
    {
      "name": "YAML alias reference",
      "scope": ["keyword.control.flow.alias.yaml"],
      "settings": { "foreground": "#a19321" }
    },
    {
      "name": "YAML directive",
      "scope": ["entity.name.directive.yaml", "punctuation.definition.directive.yaml"],
      "settings": { "foreground": "#878789" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "storage.type"],
      "settings": { "foreground": "#a19321" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.parameter"],
      "settings": { "foreground": "#2c3143" }
    },
    {
      "name": "Function",
      "scope": ["support.function", "entity.name.function"],
      "settings": { "foreground": "#a19321" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#cd3131" }
    }
  ]
}
