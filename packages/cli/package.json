{
  "name": "@galaxy-tool-util/cli",
  "version": "1.2.0",
  "description": "galaxy-tool-cache CLI — cache and inspect Galaxy tool metadata",
  "type": "module",
  "bin": {
    "galaxy-tool-cache": "dist/bin/galaxy-tool-cache.js",
    "gxwf": "dist/bin/gxwf.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./meta": {
      "types": "./dist/meta/index.d.ts",
      "import": "./dist/meta/index.js"
    }
  },
  "files": [
    "dist",
    "spec",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jmchilton/galaxy-tool-util-ts",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "node scripts/bundle-templates.mjs && tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "format-fix": "prettier --write 'src/**/*.ts' 'test/**/*.ts'"
  },
  "license": "MIT",
  "dependencies": {
    "@galaxy-tool-util/connection-validation": "workspace:*",
    "@galaxy-tool-util/core": "workspace:*",
    "@galaxy-tool-util/schema": "workspace:*",
    "@galaxy-tool-util/search": "workspace:*",
    "ajv": "^8.18.0",
    "commander": "^14.0.0",
    "effect": "^3.21.0",
    "nunjucks": "^3.2.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6"
  }
}
